{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    // Catches stay typed as `any` rather than `unknown` so the few
    // err.message accesses (network errors, Discord API errors) don't
    // each need narrowing — matches the root tsconfig convention.
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "deploy-commands.ts",
    "commands/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
