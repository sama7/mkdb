DISCORD_TOKEN=                # bot token from https://discord.com/developers/applications
clientId=                     # application ID, used by deploy-commands

# Guild(s) the bot registers slash commands to. Guild-scoped registration
# propagates instantly (global commands cache for up to 1 hour). Use a single
# `guildId=...` for dev, or any number of `guildId<Name>=...` entries for
# multiple servers — deploy-commands picks up every var matching /^guildId/i
# and PUTs the same command set to each.
guildId=                      # local dev: one server ID
# guildIdMetro=               # prod example: Metropolis server ID
# guildIdLycan=               # prod example: Lycan server ID

# URLs the bot uses when calling mkdb and linking back to it
MKDB_API_BASE_URL=            # http://localhost:3000/api/discord (dev + prod) or https://mkdb.co/api/discord
MKDB_BASE_URL=                # http://localhost:5173 (dev) or https://mkdb.co (prod)
