DISCORD_TOKEN=                # bot token from https://discord.com/developers/applications
clientId=                     # application ID, used by deploy-commands.js
guildId=                      # target Discord server ID for slash command registration

# URLs the bot uses when calling mkdb and linking back to it
MKDB_API_BASE_URL=            # http://localhost:3000/api/discord (dev + prod) or https://mkdb.co/api/discord
MKDB_BASE_URL=                # http://localhost:5173 (dev) or https://mkdb.co (prod)
