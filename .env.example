# Letterboxd API — https://api-docs.letterboxd.com/
LETTERBOXD_CLIENT_ID=
LETTERBOXD_CLIENT_SECRET=
# Required only by scripts/update-letterboxd-list.ts (chains after promote).
# Issued via the authorization_code OAuth flow; gives mutate scope on the
# owner's lists. Letterboxd doesn't rotate it on refresh.
LETTERBOXD_REFRESH_TOKEN=

# PostgreSQL — production
DB_USER=
DB_PASSWORD=

# PostgreSQL — local dev
# db/conn.js falls back to these when DB_USER / DB_PASSWORD are unset
DEV_DB_USER=
DEV_DB_PASSWORD=
DB_PORT=5432

# Express
PORT=3000
NODE_ENV=                      # set to "production" on the VPS
RATE_LIMIT_SKIP_IPS=           # optional, comma-separated IPs exempt from rate limiting (loopback already exempt)

# Discord — required only by scripts/post-weekly-update.ts (the weekly #mank
# status post). Same bot token discord-bot uses. MANK_CHANNEL_ID defaults to
# the Metropolis #mank channel if unset.
DISCORD_TOKEN=
MANK_CHANNEL_ID=

